# Test file for API HTTP routes

@endpoint = http://localhost:{{$dotenv PORT}}

### 404
GET {{ endpoint }}/somethingsmart

############################
#         ARTWORKS         #
############################

### List of all artworks
GET {{ endpoint }}/artworks

### List of all artworks from a user
GET {{ endpoint }}/artworks/user/4

### Get one artwork based on its id
GET {{ endpoint }}/artworks/6

### Create a new artwork in database if does not already exist
POST {{ endpoint }}/artworks
content-type: application/json
Authorization: Bearer eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..ebddNYWnsEf8PcaZ0JM3Utj1rHdWVdoe2mOKmPU-R_s

{
    "name": "L'origine du monde",
    "image": "imagefile",
    "description": "Lorem ipsum",
    "artist_name": "tf988",
    "price_usd": 999,
    "price_sol": 450
}

### Update an artwork data in database
PATCH {{ endpoint }}/artworks/7
content-type: application/json
Authorization: Bearer eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..ebddNYWnsEf8PcaZ0JM3Utj1rHdWVdoe2mOKmPU-R_s

{
    "description": "Lorem ipsum",
    "price_usd": 500,
    "price_sol": 500
}

### Delete an artwork data in database
DELETE {{ endpoint }}/artworks/6
Authorization: Bearer eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..ebddNYWnsEf8PcaZ0JM3Utj1rHdWVdoe2mOKmPU-R_s

############################
#       LOGIN/LOGOUT       #
############################

### User login
POST {{ endpoint }}/users/login
content-type: application/json

{
    "pseudo": "Mezange",
    "password": "NFT"
}

### User logout
POST {{ endpoint }}/users/logout
Authorization: Bearer eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..rRIeoDjDzDaJHfWl15Zj7Mr9ioz96spGj9nvam_imN4

### Invalid User login - Unauthorized
POST {{ endpoint }}/users/login
content-type: application/json

{
    "pseudo": "tf988",
    "password": "Plantey"
}

### Invalid User login - Bad request
POST {{ endpoint }}/users/login
content-type: application/json

{
    "pseudo": "Mezange"
}

############################
#         ROLES            #
############################

### List of all roles
GET {{ endpoint }}/roles

### Get one role based on its id
GET {{ endpoint }}/roles/3

############################
#      SIGNUP/SIGNOUT      #
############################

### Create a new user in database if does not already exist
POST {{ endpoint }}/users/signup
content-type: application/json

{
    "email": "test@test.com",
    "password": "Plantey",
    "country": "France",
    "pseudo": "tf988"
}

### Invalid create user request
POST {{ endpoint }}/users/signup
content-type: application/json

{
    "email": "eergergerg",
    "password": "Plantey"
}

### Delete a new user in database if exists
DELETE {{ endpoint }}/users/signout/5
Authorization: Bearer eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..BzkvUHBUYYXMqa2kzpdV8ZFehQXz3d8V9G38DGhSNh0

############################
