GET {{ endpoint }}/users/mezange
Authorization: Bearer eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..rRIeoDjDzDaJHfWl15Zj7Mr9ioz96spGj9nvam_imN4

### Update one user data in database
PATCH {{ endpoint }}/users/4
content-type: application/json
Authorization: Bearer eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..H3kES8i8qTwSKbehZSa6YIV1K4Admh-Rp8ZLHUtRVfI

